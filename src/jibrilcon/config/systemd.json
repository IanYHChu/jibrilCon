{
  "unit_dirs": [
    "/etc/systemd/system",
    "/usr/lib/systemd/system",
    "/lib/systemd/system"
  ],
  "user_unit_dir_suffix": ".config/systemd/user",
  "exec_keys": [
    "ExecStart",
    "ExecStartPre"
  ],
  "container_keywords": [
    "docker",
    "podman",
    "lxc-start",
    "kubelet",
    "k3s",
    "rke2"
  ],
  "engine_detection": {
    "docker": {
      "keyword": "docker",
      "container_regex": "--name\\s+([^\\s]+)"
    },
    "podman": {
      "keyword": "podman",
      "container_regex": "--name\\s+([^\\s]+)"
    },
    "lxc": {
      "keyword": "lxc-start",
      "container_regex": "-n\\s+([^\\s]+)"
    },
    "kubernetes": {
      "keyword": "kubelet",
      "container_regex": "--hostname-override[=\\s]+([^\\s]+)"
    },
    "k3s": {
      "keyword": "k3s",
      "container_regex": "k3s\\s+(server|agent)"
    },
    "rke2": {
      "keyword": "rke2",
      "container_regex": "rke2\\s+(server|agent)"
    }
  },
  "fields_to_keep": [
    "ExecStart",
    "ExecStartPre",
    "ExecStop",
    "User",
    "CapabilityBoundingSet",
    "AmbientCapabilities"
  ],
  "extraction_patterns": {
    "CapabilityBoundingSet": "CapabilityBoundingSet=(.*)",
    "AmbientCapabilities": "AmbientCapabilities=(.*)"
  }
}
